APP_ENV=dev
PORT=8080

TELEGRAM_BOT_TOKEN=replace_me
SUPERUSER_TELEGRAM_ID=123456789

DATABASE_URL=postgres://wallet:wallet@localhost:5432/walletra?sslmode=disable

# Scheduler intervals (cron or duration-like labels used in code defaults)
POLL_INTERVAL_MINUTES=30

# Direct Polygon provider config
POLYGON_DIRECT_PROVIDER_ENABLED=true
POLYGON_RPC_URL=https://polygon-rpc.com
POLYGON_WS_URL=
POLYGON_START_BLOCK=0
POLYGON_CONFIRMATIONS=20
POLYGON_SCAN_CHUNK_SIZE=500
